# ── DocuVerse Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in real values before running.
# Never commit .env to version control.

# OpenAI
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o-mini

# Embedding
EMBEDDING_MODEL=text-embedding-3-small

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Retrieval
TOP_K=5
# Strategy: dense | sparse | hybrid | reranked_hybrid
RETRIEVAL_STRATEGY=dense
HYBRID_DENSE_TOP_K=20
HYBRID_SPARSE_TOP_K=20
HYBRID_RRF_K=60
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_FETCH_K=50

# Vector store
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# Upload limits (6 MB in production; 25 MB locally if needed)
MAX_UPLOAD_SIZE_MB=6

# Logging
LOG_LEVEL=INFO

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit → API (supervisord overrides this to http://127.0.0.1:8000 in Docker)
API_URL=http://localhost:8000

# ── HuggingFace Spaces deployment ─────────────────────────────────────────────
# Set OPENAI_API_KEY as an HF Space "Secret" — never hardcode it here.
# HF_SPACES_MODE=true enables stricter defaults automatically.
HF_SPACES_MODE=false
DAILY_COST_CAP_INR=50
